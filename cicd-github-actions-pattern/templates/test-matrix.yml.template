name: Test

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  test:
    runs-on: ${{ matrix.os }}
    timeout-minutes: 20
    strategy:
      fail-fast: false   # one matrix cell failing must NOT abort the rest
      matrix:
        os: [ubuntu-latest]
        python: ['3.10', '3.11', '3.12']
        include:
          - os: macos-latest
            python: '3.12'
            coverage: true     # only one cell uploads coverage
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python }}
          cache: 'pip'
          cache-dependency-path: |
            requirements.txt
            requirements-dev.txt

      - name: Install
        run: |
          pip install -r requirements.txt -r requirements-dev.txt
          pip install -e .

      - name: pytest
        run: pytest -v --tb=short

      - name: Coverage (single cell)
        if: ${{ matrix.coverage }}
        run: |
          pytest --cov --cov-report=term-missing --cov-fail-under=80
