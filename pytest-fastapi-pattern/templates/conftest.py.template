# 지연 import — 환경변수 셋업 후에만
from myapp import config as app_config  # noqa: E402
from myapp.db import get_engine, reset_engine  # noqa: E402
from myapp.models import Base  # noqa: E402

app_config.get_settings.cache_clear()


# ── 2) DB fixture (function scope = 매 테스트 격리) ──────────────────────────
@pytest_asyncio.fixture
async def app_db() -> AsyncIterator[None]:
    """매 테스트마다 깨끗한 테이블."""
    await reset_engine()
    engine = get_engine()
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    yield
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.drop_all)
    await reset_engine()


# ── 3) ASGITransport client (lifespan 포함) ──────────────────────────────────
@pytest_asyncio.fixture
async def client(app_db: None) -> AsyncIterator[AsyncClient]:
    """in-process httpx async client.

    httpx 0.27+ 는 lifespan="on" 으로 자동 startup/shutdown.
    그 이전이면 ``asgi_lifespan.LifespanManager`` 로 감싸기.
    """
    from myapp.main import create_app

    app = create_app()
    transport = ASGITransport(app=app)  # httpx 0.27+: lifespan="on" 추가
    async with AsyncClient(transport=transport, base_url="http://test") as c:
        yield c


# ── 4) 헬퍼 ──────────────────────────────────────────────────────────────────
@pytest.fixture
def admin_headers() -> dict[str, str]:
    return {"X-Admin-Key": "test_admin_key"}


@pytest_asyncio.fixture
async def auth_headers(client: AsyncClient, admin_headers: dict[str, str]) -> dict[str, str]:
    """API 키 발급 후 Bearer 헤더."""
    user = (await client.post("/admin/users", headers=admin_headers,
                              json={"username": "t", "email": "t@x"})).json()
    key = (await client.post("/admin/keys", headers=admin_headers,
                             json={"user_id": user["id"], "name": "k"})).json()
    return {"Authorization": f"Bearer {key['raw_key']}"}


def make_upstream_response(*, content: str = "ok") -> dict:
    """upstream JSON 응답 빌더 (테스트 안에서 import)."""
    return {"id": "x-1", "choices": [{"message": {"content": content}}],
            "usage": {"prompt_tokens": 1, "completion_tokens": 1, "total_tokens": 2}}
