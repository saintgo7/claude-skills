"""SSE 스트리밍 프록시 라우트 (httpx async stream).

OpenAI 호환 게이트웨이가 업스트림 (vLLM 등) 의 SSE chunk 를 끊김 없이
클라이언트에 forward 하는 표준 패턴.

원칙:
  - `httpx.AsyncClient` 를 lifespan 에서 만들어 재사용 (TCP 핸드셰이크 절약)
  - `aiter_bytes()` 사용 — `aiter_text()` 는 UTF-8 chunk 경계 깨짐
  - read timeout = None — SSE 는 chunk 사이 간격이 길 수 있음
  - 가공 없이 yield — `[DONE]` 도 그대로 클라이언트가 처리
"""
from __future__ import annotations

from typing import AsyncIterator

import httpx
from fastapi import APIRouter, HTTPException, Request
from fastapi.responses import StreamingResponse

router = APIRouter()
UPSTREAM_URL = "http://127.0.0.1:8000/v1/chat/completions"  # TODO


async def _stream_upstream(
    client: httpx.AsyncClient,
    payload: dict,
    headers: dict,
) -> AsyncIterator[bytes]:
    timeout = httpx.Timeout(connect=5.0, read=None, write=10.0, pool=5.0)
    async with client.stream(
        "POST", UPSTREAM_URL, json=payload, headers=headers, timeout=timeout
    ) as resp:
        if resp.status_code >= 400:
            body = await resp.aread()
            raise HTTPException(resp.status_code, detail=body.decode("utf-8", "ignore"))
        async for chunk in resp.aiter_bytes():
            yield chunk  # SSE chunk 그대로 forward


@router.post("/v1/chat/completions")
async def chat(request: Request, body: dict) -> StreamingResponse:
    client: httpx.AsyncClient = request.app.state.http  # lifespan 에서 만든 것

    # 인증 헤더 등 필요한 것만 forward (Host/Content-Length 는 제외)
    fwd_headers = {
        k: v for k, v in request.headers.items()
        if k.lower() in {"authorization", "x-request-id"}
    }

    if not body.get("stream"):
        # non-streaming 도 같은 라우트로 받으려면 분기
        async with client.stream("POST", UPSTREAM_URL, json=body, headers=fwd_headers) as r:
            return StreamingResponse(r.aiter_bytes(), media_type="application/json")

    return StreamingResponse(
        _stream_upstream(client, body, fwd_headers),
        media_type="text/event-stream",
    )
