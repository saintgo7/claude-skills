          "legendFormat": "model={{model}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Chat completions rate (by model)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "P50 / P95 / P99 chat completion latency from <service>_chat_latency_ms histogram, broken down by model.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 2000
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, model) (rate(<service>_chat_latency_ms_bucket[5m])))",
          "legendFormat": "p50 {{model}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(<service>_chat_latency_ms_bucket[5m])))",
          "legendFormat": "p95 {{model}}",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le, model) (rate(<service>_chat_latency_ms_bucket[5m])))",
          "legendFormat": "p99 {{model}}",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Chat latency p50 / p95 / p99 (by model)",
      "type": "timeseries"
    },
