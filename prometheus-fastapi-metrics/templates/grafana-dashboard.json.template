        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "nvidia_smi_utilization_gpu_ratio * 100 or DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "gpu={{gpu}} ({{Hostname}})",
          "range": true,
          "refId": "A"
        }
