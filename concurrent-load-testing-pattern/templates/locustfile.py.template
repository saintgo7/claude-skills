"""
locustfile — 표준 LLM 부하 테스트 (4 워크로드 가중치).

사용:
  KEY=gem_live_xxxx locust -f locustfile.py --host http://gw:8080 \
    --headless --users 50 --spawn-rate 5 --run-time 60s --csv=report

워크로드:
  short_chat     50%  — 짧은 대화
  coding         30%  — 코드 생성
  long_context   15%  — 긴 컨텍스트
  streaming       5%  — SSE
"""
import os
import random

from locust import HttpUser, between, task


MODEL = os.environ.get("LOCUST_MODEL", "exaone")


class LLMUser(HttpUser):
    wait_time = between(1, 3)

    def on_start(self):
        key = os.environ.get("KEY")
        if not key:
            raise RuntimeError("set KEY=<api-key>")
        self.headers = {"Authorization": f"Bearer {key}"}

    # ── 50% 짧은 대화 ────────────────────────────────────────────────────
    @task(50)
    def short_chat(self):
        self.client.post(
            "/v1/chat/completions",
            headers=self.headers,
            json={
                "model": MODEL,
                "messages": [{"role": "user", "content": "Say hello briefly."}],
                "max_tokens": 32,
            },
            name="short_chat",
        )

    # ── 30% 코드 생성 ────────────────────────────────────────────────────
    @task(30)
    def coding(self):
        self.client.post(
            "/v1/chat/completions",
            headers=self.headers,
            json={
                "model": MODEL,
                "messages": [{"role": "user", "content": "Write a Python fibonacci function."}],
                "max_tokens": 256,
            },
            name="coding",
        )

    # ── 15% 긴 컨텍스트 ─────────────────────────────────────────────────
    @task(15)
    def long_context(self):
        big = "lorem ipsum " * 500
        self.client.post(
            "/v1/chat/completions",
            headers=self.headers,
            json={
                "model": MODEL,
                "messages": [
                    {"role": "system", "content": big},
                    {"role": "user", "content": "Summarize in one sentence."},
                ],
                "max_tokens": 64,
            },
            name="long_context",
        )

    # ── 5% 스트리밍 ─────────────────────────────────────────────────────
    @task(5)
    def streaming(self):
        with self.client.post(
            "/v1/chat/completions",
            headers=self.headers,
            json={
                "model": MODEL,
                "messages": [{"role": "user", "content": "Count to ten."}],
                "max_tokens": 64,
                "stream": True,
            },
            name="streaming",
            stream=True,
            catch_response=True,
        ) as resp:
            for _ in resp.iter_lines():
                pass
            resp.success()
