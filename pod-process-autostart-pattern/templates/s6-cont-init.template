#!/bin/sh
# =============================================================================
# /etc/cont-init.d/<NN>-<name>
# s6-overlay cont-init.d hook — runs once when the pod starts.
# Place file with chmod 755.  NN controls execution order (50 < 60).
#
# Replace:
#   <NN>             — execution order (10/20/.../99)
#   <name>           — process name (e.g. cloudflared, sshd)
#   <unique-pattern> — pgrep -f pattern (full command, unique enough)
#   <command>        — absolute command line
#   <log-path>       — persistent volume preferred (NOT /var/log on tmpfs)
# -----------------------------------------------------------------------------

set -e

LOG_DIR="$(dirname <log-path>)"
mkdir -p "$LOG_DIR"

if pgrep -f "<unique-pattern>" >/dev/null 2>&1; then
  echo "[cont-init] <name> already running — skip"
  exit 0
fi

echo "[cont-init] starting <name>"
nohup <command> >> <log-path> 2>&1 &

# Always exit 0 so a failed start does NOT block pod boot.
exit 0
